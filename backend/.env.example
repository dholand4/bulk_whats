PORT=3000

# Use DATABASE_URL em producao se preferir uma unica string de conexao.
# Exemplo: postgres://postgres:sua_senha@localhost:5432/bulk_whats
DATABASE_URL=

PGHOST=localhost
PGPORT=5432
PGDATABASE=bulk_whats
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=

# Ambiente local (Windows)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Containers Linux / producao com Docker
PUPPETEER_EXECUTABLE_PATH=
